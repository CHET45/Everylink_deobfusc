<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="bottom|center_horizontal"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/iv2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0x7f07027d"
        android:src="@mipmap/guide_home_list2"/>
    <ImageView
        android:layout_gravity="right"
        android:id="@+id/iv1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="0x7f070280"
        android:src="@mipmap/guide_home_add2"
        android:layout_marginEnd="0x7f07027f"/>
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/iv0"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="0x7f07028d"
        android:src="@mipmap/guide_home_list1"/>
</LinearLayout>
