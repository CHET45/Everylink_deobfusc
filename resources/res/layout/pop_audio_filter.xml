<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="0x7f070281"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/up_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@mipmap/arrow_up"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/popup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-3dp">
        <TextView
            android:textSize="0x7f0702b1"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/filter_all"
            android:background="@drawable/ripple_bg_trans_top"
            android:padding="0x7f07027d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_all"/>
        <View style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b1"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/filter_sync"
            android:background="@drawable/ripple_bg_trans_center"
            android:padding="0x7f07027d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_sync"/>
        <View style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b1"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/filter_dis_sync"
            android:background="@drawable/ripple_bg_trans_center"
            android:padding="0x7f07027d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_dis_sync"/>
        <View style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b1"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/filter_transcribe"
            android:background="@drawable/ripple_bg_trans_center"
            android:padding="0x7f07027d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_transcribe"/>
        <View style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b1"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/filter_dis_transcribe"
            android:background="@drawable/ripple_bg_trans_center"
            android:padding="0x7f07027d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_dis_transcribe"/>
        <View
            android:id="@+id/line_auth"
            style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b1"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/filter_auth"
            android:background="@drawable/ripple_bg_trans_center"
            android:padding="0x7f07027d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_auth"/>
        <View
            android:id="@+id/line_disauth"
            style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b1"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/filter_dis_auth"
            android:background="@drawable/ripple_bg_trans_bottom"
            android:padding="0x7f07027d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_dis_auth"/>
    </LinearLayout>
</LinearLayout>
