<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/bg_color_popup_bar"
    app:cardCornerRadius="20dp">
    <RelativeLayout
        android:layout_gravity="center"
        android:paddingBottom="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:id="@+id/top"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_alignParentTop="true"
            android:layout_marginHorizontal="20dp">
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_primary"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <RelativeLayout
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/imgView"
                android:padding="0x7f070280"
                android:visibility="gone"
                android:layout_width="0x7f070283"
                android:layout_height="0x7f070283">
                <ImageView
                    android:id="@+id/img"
                    android:layout_width="0x7f070283"
                    android:layout_height="0x7f070283"
                    android:scaleType="fitXY"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>
        </FrameLayout>
        <View
            android:id="@+id/line1"
            android:background="@color/line_h"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@+id/top"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/message_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp"
            android:layout_below="@+id/top"
            android:layout_marginHorizontal="20dp">
            <TextView
                android:textSize="17sp"
                android:textColor="@color/txt_color_primary"
                android:gravity="center"
                android:id="@+id/message"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:textSize="0x7f0702b2"
                android:textColor="@color/gray_3"
                android:id="@+id/edittext_id"
                android:background="@drawable/button_click_up_white_stroke"
                android:padding="0x7f070280"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="0x7f070280"
                android:maxLines="5"
                android:layout_marginStart="0x7f070280"
                android:layout_marginEnd="0x7f070280"/>
            <com.aivox.base.view.MaxHeightListView
                android:id="@+id/listview"
                android:visibility="gone"
                android:scrollbars="none"
                android:fadingEdgeLength="0dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:listSelector="@drawable/ripple_bg_noborder"
                android:cacheColorHint="@android:color/transparent"
                android:divider="@color/line_h"
                android:dividerHeight="1dp"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/ll_check_box"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp">
                <CheckBox
                    android:id="@+id/cb_dialog"
                    android:clickable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:button="@drawable/check_box_dialog"
                    android:scaleX="0.5"
                    android:scaleY="0.5"/>
                <TextView
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/txt_color_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_longer_shows"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:id="@+id/line2"
            android:visibility="gone"
            android:layout_marginLeft="0x7f070280"
            android:layout_marginRight="0x7f070280"
            android:layout_below="@+id/message_layout"
            style="@style/Line"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/btns_layout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:layout_below="@+id/message_layout"
            android:layout_marginHorizontal="24dp">
            <Button
                android:textSize="16sp"
                android:textColor="@color/txt_color_primary"
                android:id="@+id/left"
                android:background="@drawable/bg_dialog_btn_stroke"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/center"
                android:layout_width="16dp"
                android:layout_height="match_parent"
                android:layout_marginTop="0x7f07027d"
                android:layout_marginBottom="0x7f07027d"
                android:src="@android:color/transparent"/>
            <Button
                android:textSize="16sp"
                android:textColor="@color/txt_color_secondary"
                android:id="@+id/right"
                android:background="@drawable/bg_dialog_btn_solid"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/iv_cancel"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:src="@drawable/ic_close_x"
            android:alpha="0.4"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
