<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/fragment_gallary_0"
    android:background="@color/bg_color_secondary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="22sp"
        android:textColor="@color/txt_color_primary"
        android:gravity="center"
        android:id="@+id/tv_title"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/iv_settings"
        android:tag="binding_1"
        android:padding="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_gallery_settings"
        android:contentDescription="@null"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_title"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_tab"
        android:background="@drawable/bg_gray_c12"
        android:padding="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/tv_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_title">
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black_text"
            android:gravity="center"
            android:id="@+id/tv_all"
            android:tag="binding_2"
            android:background="@drawable/bg_white_c10"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:text="@string/all"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black_text"
            android:gravity="center"
            android:id="@+id/tv_photo"
            android:tag="binding_3"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:text="@string/photos"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black_text"
            android:gravity="center"
            android:id="@+id/tv_video"
            android:tag="binding_4"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:text="@string/videos"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black_text"
            android:gravity="center"
            android:id="@+id/tv_favorite"
            android:tag="binding_5"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:text="@string/favorite"/>
    </LinearLayout>
    <TextView
        android:textSize="24sp"
        android:gravity="center"
        android:id="@+id/tv_select_count"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/gallery_purple"
        android:gravity="center"
        android:id="@+id/tv_select_all"
        android:tag="binding_6"
        android:background="@drawable/bg_purple_c16_stroke"
        android:visibility="invisible"
        android:layout_width="64dp"
        android:layout_height="32dp"
        android:layout_margin="16dp"
        android:text="@string/action_select_all"
        app:layout_constraintBottom_toBottomOf="@+id/ll_tab"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/ll_tab"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_complete"
        android:tag="binding_7"
        android:background="@drawable/bg_purple_c16"
        android:visibility="invisible"
        android:layout_width="64dp"
        android:layout_height="32dp"
        android:layout_margin="16dp"
        android:text="@string/done"
        app:layout_constraintBottom_toBottomOf="@+id/ll_tab"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/ll_tab"/>
    <RelativeLayout
        android:id="@+id/rl_sync"
        android:background="@color/gallery_bg_purple"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_sync"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_gallery_img"
                android:contentDescription="@null"/>
            <TextView
                android:textColor="@color/black_20"
                android:id="@+id/tv_file_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"/>
            <TextView
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/tv_sync"
                android:tag="binding_8"
                android:background="@drawable/bg_purple_c16"
                android:layout_width="64dp"
                android:layout_height="32dp"
                android:text="@string/do_import"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_sync_progress"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/cpi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:progress="0"
                android:indeterminate="false"
                android:layout_centerInParent="true"
                app:indicatorColor="@color/gallery_purple"
                app:indicatorDirectionCircular="clockwise"
                app:indicatorSize="28dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:trackColor="@color/gallery_track_color"
                app:trackCornerRadius="2dp"
                app:trackThickness="4dp"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/gallery_purple"
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@+id/cpi"
                app:layout_constraintEnd_toEndOf="@+id/cpi"
                app:layout_constraintStart_toStartOf="@+id/cpi"
                app:layout_constraintTop_toTopOf="@+id/cpi"/>
            <TextView
                android:textColor="@color/black_20"
                android:id="@+id/tv_file"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toTopOf="@+id/tv_hint"
                app:layout_constraintStart_toEndOf="@+id/cpi"
                app:layout_constraintTop_toTopOf="@+id/cpi"/>
            <TextView
                android:textColor="@color/gallery_purple"
                android:id="@+id/tv_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/do_not_leave_app"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/cpi"
                app:layout_constraintStart_toEndOf="@+id/cpi"
                app:layout_constraintTop_toBottomOf="@+id/tv_file"/>
            <ImageView
                android:id="@+id/iv_cancel"
                android:tag="binding_9"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_gallery_cancel"
                android:contentDescription="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
    <View
        android:background="@color/bg_color_divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@+id/ll_tab"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_gallery"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10.5dp"
        app:layout_constraintBottom_toTopOf="@+id/gl_function"
        app:layout_constraintTop_toBottomOf="@+id/rl_sync"/>
    <GridLayout
        android:id="@+id/gl_function"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rv_gallery">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/ll_save"
            android:tag="binding_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:paddingVertical="13dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_gallery_save"
                android:scaleType="fitXY"
                android:contentDescription="@null"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/black_20"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/save"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/ll_favorite"
            android:tag="binding_11"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:paddingVertical="13dp">
            <ImageView
                android:id="@+id/iv_favorite"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_gallery_favorite"
                android:scaleType="fitXY"
                android:contentDescription="@null"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/black_20"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/favorite"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/ll_delete"
            android:tag="binding_12"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:paddingVertical="13dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_gallery_delete"
                android:scaleType="fitXY"
                android:contentDescription="@null"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/black_20"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/delete"/>
        </LinearLayout>
    </GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
