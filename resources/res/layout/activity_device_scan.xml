<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/activity_device_scan_0"
    android:background="@color/bg_color_secondary"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.aivox.common_ui.HeadTitleLinearView
        android:id="@+id/title_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:common_right_icon1_ids="@drawable/ic_more_info"
        app:common_right_icon1_isVisible="true"
        app:common_title_txt="@string/device_manager"
        app:layout_constraintTop_toTopOf="parent"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:background="@color/bg_color_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/txt_color_primary"
                android:gravity="center"
                android:id="@+id/tv_sub_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/earphone_support_tips"
                android:paddingHorizontal="32dp"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/txt_color_primary"
                android:id="@+id/tv_earphone_steps"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginTop="16dp"
                android:text="@string/earphone_connect_tip"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_sub_title"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_primary"
                android:id="@+id/tv_register_device"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_connect"
                android:layout_marginStart="20dp"
                android:paddingVertical="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_earphone_steps"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_connect_device"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_register_device">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rcv_devices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ll_btm_notify"
                    android:background="@drawable/bg_detail_notify"
                    android:padding="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/rcv_devices">
                    <ImageView
                        android:id="@+id/iv_loading"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_btn_loading"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/txt_color_tertiary"
                        android:id="@+id/tv_msg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_searching"
                        android:layout_marginStart="16dp"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_primary"
                android:id="@+id/tv_more_devices"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_more"
                android:layout_marginStart="20dp"
                android:paddingVertical="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ll_connect_device"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_more_devices"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="12dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_more_devices"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_connect_fail"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:layout_constraintTop_toBottomOf="@+id/tv_sub_title">
                <TextView
                    android:textColor="#acb8c2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/check_by_following_step"/>
                <TextView
                    android:textColor="@color/black_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="68dp"
                    android:text="@string/check_steps"/>
                <TextView
                    android:textColor="@color/white"
                    android:id="@+id/tv_connect"
                    android:background="@drawable/bg_btn_grad_dark"
                    android:padding="0x7f070280"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/retry"
                    style="@style/Btn_Logout_stroke"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</LinearLayout>
