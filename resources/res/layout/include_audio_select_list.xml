<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingLeft="0x7f070284"
    android:paddingRight="0x7f070284"
    android:paddingBottom="0x7f070280"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_1"
        android:background="@drawable/button_click_white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="0x7f0702b2"
            android:textColor="@color/gray_3"
            android:gravity="center"
            android:id="@+id/tv_share"
            android:padding="0x7f070282"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/file_share"
            app:layout_constraintTop_toTopOf="parent"/>
        <View
            android:id="@+id/line_phone"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_share"
            style="@style/Line"/>
        <TextView
            android:textSize="0x7f0702b2"
            android:textColor="@color/gray_3"
            android:gravity="center"
            android:id="@+id/tv_delete"
            android:padding="0x7f070282"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/file_delete"
            app:layout_constraintTop_toBottomOf="@+id/line_phone"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        android:textSize="0x7f0702b1"
        android:textStyle="bold"
        android:textColor="@color/dialog_cancel"
        android:gravity="center"
        android:id="@+id/tv_cancel"
        android:background="@drawable/button_click_gray"
        android:padding="0x7f070280"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0x7f070280"
        android:text="@string/cancel_"
        app:layout_constraintTop_toBottomOf="@+id/cl_1"/>
</androidx.constraintlayout.widget.ConstraintLayout>
