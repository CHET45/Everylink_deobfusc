<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:tag="layout/item_msg_0"
    android:background="@drawable/bg_white_rad_8"
    android:paddingLeft="0x7f070280"
    android:paddingBottom="0x7f070280"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="0x7f070280"
    android:layout_marginTop="0x7f07028e"
    android:layout_marginRight="0x7f070280">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_center"
        android:paddingTop="0x7f070280"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="0x7f070280"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="0x7f0702b5"
            android:textColor="@color/txt_black"
            android:ellipsize="end"
            android:id="@+id/tv_msg_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="0x7f070280"
            android:maxLines="2"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="0x7f0702b0"
            android:gravity="center"
            android:id="@+id/tv_time"
            android:paddingRight="0x7f070280"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0x7f070289"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_msg_title"/>
        <TextView
            android:textSize="0x7f0702b3"
            android:textColor="@color/color_b7b7b7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0x7f07028e"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_msg_title"/>
        <ImageView
            android:id="@+id/iv_msg_unread"
            android:visibility="gone"
            android:layout_width="0x7f07027d"
            android:layout_height="0x7f07027d"
            android:src="@drawable/dot_red"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_del"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/cl_center"
        app:layout_constraintLeft_toRightOf="@+id/cl_center"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/tv_del"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:src="@mipmap/ic_my_msg_delete"
            android:paddingStart="0x7f070284"
            android:paddingEnd="0x7f070284"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
