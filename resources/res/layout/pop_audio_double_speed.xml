<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/up_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@mipmap/arrow_up"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/popup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="0x7f07027f">
        <TextView
            android:textSize="0x7f0702b2"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/speed_2x"
            android:background="@drawable/recordinfo_bg_trans_top"
            android:padding="0x7f070280"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2X"/>
        <View style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b2"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/speed_1_5x"
            android:background="@drawable/recordinfo_bg_trans_center"
            android:padding="0x7f070280"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.5X"/>
        <View style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b2"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/speed_1x"
            android:background="@drawable/recordinfo_bg_trans_center"
            android:padding="0x7f070280"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1X"/>
        <View style="@style/Line_popup"/>
        <TextView
            android:textSize="0x7f0702b2"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/speed_0_5x"
            android:background="@drawable/recordinfo_bg_trans_bottom"
            android:padding="0x7f070280"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.5X"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/down_arrow"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0x7f070285"
        android:layout_marginTop="-1dp"
        android:src="@mipmap/arraw_down"/>
</LinearLayout>
