<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/button_click_up_dialog_bgcolor"
    android:paddingBottom="0x7f070284"
    android:fitsSystemWindows="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_header"
        android:padding="0x7f070280"
        android:fitsSystemWindows="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintLeft_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="@dimen/font_17sp"
            android:textColor="@color/black_11"
            android:gravity="center"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="@dimen/dp_4"
            app:drawableRightCompat="@mipmap/ic_file_edit_title"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="0x7f0702af"
            android:textColor="@color/dialog_cancel_gray"
            android:id="@+id/tv_create_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0x7f070289"
            android:drawablePadding="2dp"
            app:drawableLeftCompat="@mipmap/ic_file_create_at"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="@+id/tv_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
        <TextView
            android:textSize="0x7f0702af"
            android:textColor="@color/dialog_cancel_gray"
            android:id="@+id/tv_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="2dp"
            android:layout_marginStart="0x7f070280"
            app:drawableLeftCompat="@mipmap/ic_file_duration"
            app:layout_constraintBottom_toBottomOf="@+id/tv_create_at"
            app:layout_constraintLeft_toRightOf="@+id/tv_create_at"/>
        <TextView
            android:textSize="0x7f0702af"
            android:textColor="@color/dialog_cancel_gray"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/tv_audio_address"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:maxLength="7"
            android:drawablePadding="2dp"
            android:layout_marginStart="0x7f070280"
            app:drawableLeftCompat="@mipmap/ic_file_location"
            app:layout_constraintBottom_toBottomOf="@+id/tv_create_at"
            app:layout_constraintLeft_toRightOf="@+id/tv_duration"/>
        <ImageView
            android:id="@+id/iv_cloud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_file_cloud"
            android:layout_marginStart="0x7f070280"
            app:layout_constraintBottom_toBottomOf="@+id/tv_create_at"
            app:layout_constraintLeft_toRightOf="@+id/tv_audio_address"
            app:layout_constraintTop_toTopOf="@+id/tv_create_at"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@+id/pop_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_header"/>
</androidx.constraintlayout.widget.ConstraintLayout>
