<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:tag="layout/device_activate_dialog_layout_0"
    android:background="@drawable/bg_dialog_bottom_dark"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="20dp">
    <com.aivox.common_ui.DialogTitleView
        android:id="@+id/dtv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:dtv_title="@string/device_activate_title"/>
    <TextView
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_activate_success"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/device_activate_success"
        android:drawablePadding="8dp"
        android:paddingVertical="8dp"
        app:drawableStartCompat="@drawable/ic_connect_success"/>
    <TextView
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_activate_failed"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/device_activate_error"
        android:drawablePadding="8dp"
        android:paddingVertical="8dp"
        app:drawableStartCompat="@drawable/ic_connect_failed"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/txt_color_primary"
        android:gravity="center"
        android:id="@+id/tv_activate_msg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/device_activate_msg"
        android:paddingVertical="8dp"/>
    <ImageView
        android:id="@+id/iv_device_icon"
        android:layout_width="220dp"
        android:layout_height="220dp"/>
</LinearLayout>
