<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/activity_user_info_0"
    android:background="@color/bg_color_secondary"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.aivox.common_ui.HeadTitleLinearView
        android:id="@+id/title_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:common_title_txt="@string/my_page_account_info"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_head"
        android:tag="binding_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@+id/title_view">
        <TextView
            android:textSize="100sp"
            android:textStyle="bold"
            android:textColor="@color/txt_color_secondary"
            android:gravity="center"
            android:id="@+id/tv_head"
            android:background="@drawable/bg_purple_round"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:maxLength="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.aivox.common_ui.RoundedCornerBitmap
            android:id="@+id/iv_head"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            app:layout_constraintBottom_toBottomOf="@+id/tv_head"
            app:layout_constraintEnd_toEndOf="@+id/tv_head"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_head">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/cl_center"
            android:paddingTop="40dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.aivox.common_ui.SettingTileView
                android:id="@+id/stv_nickname"
                android:tag="binding_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tile_right_icon="@drawable/ic_info_edit"
                app:tile_show_divider="true"
                app:tile_title="@string/set_nickname"/>
            <com.aivox.common_ui.SettingTileView
                android:id="@+id/stv_birthday"
                android:tag="binding_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tile_right_icon="@drawable/ic_info_edit"
                app:tile_show_divider="true"
                app:tile_title="@string/set_birth"/>
            <com.aivox.common_ui.SettingTileView
                android:id="@+id/stv_gender"
                android:tag="binding_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tile_right_icon="@drawable/ic_info_edit"
                app:tile_show_divider="true"
                app:tile_title="@string/set_gender"/>
            <com.aivox.common_ui.SettingTileView
                android:id="@+id/stv_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tile_right_icon="@drawable/ic_info_edit"
                app:tile_show_divider="true"
                app:tile_show_right_icon="false"
                app:tile_title="@string/set_account"/>
            <com.aivox.common_ui.SettingTileView
                android:id="@+id/stv_pwd"
                android:tag="binding_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tile_right_icon="@drawable/ic_info_edit"
                app:tile_show_divider="true"
                app:tile_title="@string/set_account_security_pwd"/>
            <com.aivox.common_ui.LoadingButton
                android:id="@+id/tv_sign_out"
                android:tag="binding_6"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="24dp"
                app:lb_buttonType="normal"
                app:lb_text="@string/set_exit"/>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/txt_color_warning"
                android:gravity="center"
                android:id="@+id/tv_delete_account"
                android:tag="binding_7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/delete_account"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
