<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/speaker_num_select_view_layout_0"
    android:background="@drawable/bg_dialog_bottom_dark"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="20dp">
    <TextView
        android:textSize="34sp"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/record_pop_speaker"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/txt_color_tertiary"
        android:id="@+id/tv_dialog_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/speaker_num_select_msg"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">
        <SeekBar
            android:id="@+id/sb_speaker_num"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:max="10"
            android:layout_weight="1"
            style="@style/AudioPlaySeekBarStyle"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/txt_color_primary"
            android:gravity="end"
            android:id="@+id/tv_speaker_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/speaker_num_auto"/>
    </LinearLayout>
    <com.aivox.common_ui.LoadingButton
        android:id="@+id/btn_continue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginVertical="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:lb_text="@string/do_continue"/>
</LinearLayout>
