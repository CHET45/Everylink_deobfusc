<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_bg"
    android:tag="layout/fragment_record_transcribe_0"
    android:background="@color/bg_color_secondary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbar"
            android:background="@android:color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="0dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_audio_title"
                android:focusableInTouchMode="true"
                android:visibility="invisible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                app:layout_scrollFlags="enterAlways|scroll">
                <TextView
                    android:textSize="22sp"
                    android:textColor="@color/txt_color_primary"
                    android:ellipsize="end"
                    android:id="@+id/tv_record_title"
                    android:background="@color/bg_color_secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:maxLength="25"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/txt_color_primary"
                    android:id="@+id/tv_record_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_record_title"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/txt_color_primary"
                    android:id="@+id/tv_record_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="00:00:00"
                    android:drawablePadding="2dp"
                    app:drawableStartCompat="@drawable/ic_audio_wave"
                    app:layout_constraintBaseline_toBaselineOf="@+id/tv_record_date"
                    app:layout_constraintStart_toEndOf="@+id/tv_record_date"
                    app:layout_constraintTop_toBottomOf="@+id/tv_record_title"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/txt_color_primary"
                    android:ellipsize="end"
                    android:id="@+id/tv_record_location"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:maxLines="1"
                    android:drawablePadding="2dp"
                    app:drawableStartCompat="@drawable/ic_location"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintBaseline_toBaselineOf="@+id/tv_record_date"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintStart_toEndOf="@+id/tv_record_time"/>
                <View
                    android:id="@+id/view_cover_title"
                    android:background="@color/bg_color_secondary"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:alpha="0.6"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ll_switch"
                    android:background="@drawable/bg_switch_layout"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginVertical="8dp"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/txt_color_secondary"
                        android:gravity="center"
                        android:id="@+id/tv_switch_content"
                        android:background="@drawable/bg_switch_select"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:text="@string/trans_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"/>
                    <TextView
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/txt_color_primary"
                        android:gravity="center"
                        android:id="@+id/tv_switch_summary"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:text="@string/ai_summary"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"/>
                </LinearLayout>
                <View
                    android:id="@+id/view_cover_switch"
                    android:background="@color/bg_color_secondary"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:alpha="0.6"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <RelativeLayout
            android:paddingTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_trans_list"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"/>
            <RelativeLayout
                android:id="@+id/rl_chat_layout"
                android:background="@color/bg_color_secondary"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="20dp">
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/txt_color_primary"
                    android:id="@+id/tv_chat_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_chat_empty_holder"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_chat_list"
                    android:background="@color/bg_color_secondary"
                    android:visibility="invisible"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:overScrollMode="never"/>
            </RelativeLayout>
        </RelativeLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <TextView
        android:id="@+id/btn_to_transcribe"
        android:visibility="gone"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0x7f070284"
        android:layout_marginTop="0x7f07028a"
        android:layout_marginRight="0x7f070284"
        android:text="@string/to_file_word"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/Btn_Logout"/>
    <ImageView
        android:id="@+id/iv_to_bottom"
        android:background="@drawable/bg_purple_round"
        android:padding="12dp"
        android:visibility="invisible"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginBottom="8dp"
        android:src="@drawable/ic_arrow_down"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_search_list"
        android:background="@color/bg_color_secondary"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
