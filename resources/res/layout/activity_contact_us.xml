<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/main"
    android:tag="layout/activity_contact_us_0"
    android:background="@color/bg_color_secondary"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.aivox.common_ui.HeadTitleLinearView
        android:id="@+id/title_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:common_right_icon1_ids="@drawable/ic_close_x"
        app:common_right_icon1_isVisible="false"
        app:common_title_txt="@string/contact_us"/>
    <TextView
        android:textColor="@color/txt_color_tertiary"
        android:layout_gravity="center_horizontal"
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="4dp"
        android:text="33%"/>
    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginBottom="48dp"
        android:progress="33"
        android:progressDrawable="@drawable/progress_time_left_normal"
        android:layout_marginHorizontal="20dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/iv_submit_success"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_submit_success"
        android:layout_marginVertical="32dp"/>
    <TextView
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/txt_color_primary"
        android:layout_gravity="center_horizontal"
        android:id="@+id/tv_step_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/contact_us_step_1"/>
    <FrameLayout
        android:id="@+id/fl_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="20dp">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_step_1"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="17sp"
                android:textColor="@color/txt_color_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contact_us_account"
                android:layout_marginVertical="8dp"/>
            <TextView
                android:textSize="17sp"
                android:textColor="@color/txt_color_tertiary"
                android:gravity="center_vertical"
                android:id="@+id/tv_account"
                android:background="@drawable/bg_gary_input_c20"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginVertical="8dp"
                android:paddingHorizontal="16dp"/>
            <TextView
                android:textSize="17sp"
                android:textColor="@color/txt_color_primary"
                android:id="@+id/tv_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contact_us_email"
                android:layout_marginVertical="8dp"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_email"
                android:background="@drawable/bg_gary_input_c20"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginVertical="8dp"
                android:paddingHorizontal="16dp">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/iv_format_notice"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_login_error"/>
                <EditText
                    android:textSize="17sp"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/et_email"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/contact_us_email_notice"
                    android:layout_weight="1"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionDone"
                    style="@style/SearchEditTextStyle"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_quick_set"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp">
                <CheckBox
                    android:id="@+id/cb_email"
                    android:clickable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:button="@drawable/check_box_dialog"
                    android:scaleX="0.6"
                    android:scaleY="0.6"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/txt_color_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_us_quick_set"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_step_2"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="17sp"
                android:textColor="@color/txt_color_primary"
                android:id="@+id/tv_tags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contact_us_tags"
                android:layout_marginVertical="8dp"/>
            <com.zhy.view.flowlayout.TagFlowLayout
                android:id="@+id/tag_flow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:max_select="2"/>
        </LinearLayout>
        <ScrollView
            android:id="@+id/sv_step_3"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/txt_color_primary"
                    android:id="@+id/tv_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_us_message"
                    android:layout_marginVertical="8dp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/ll_msg"
                    android:background="@drawable/bg_gary_input_c20"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/iv_msg_empty"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:src="@drawable/ic_login_error"/>
                        <EditText
                            android:textSize="17sp"
                            android:layout_gravity="center_vertical"
                            android:id="@+id/et_msg"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:hint=""
                            android:maxLines="999"
                            android:maxLength="300"
                            android:layout_weight="1"
                            android:inputType="textMultiLine"
                            android:imeOptions="actionDone"
                            style="@style/SearchEditTextStyle"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/txt_color_tertiary"
                        android:layout_gravity="end"
                        android:id="@+id/tv_text_count"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0/300"/>
                </LinearLayout>
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/txt_color_primary"
                    android:id="@+id/tv_files"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/txt_color_tertiary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_us_file_limit"
                    android:layout_marginVertical="8dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_files"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/ll_submit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp">
                    <CheckBox
                        android:layout_gravity="center_vertical"
                        android:id="@+id/cb_submit"
                        android:clickable="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:button="@drawable/check_box_dialog"
                        android:scaleX="0.6"
                        android:scaleY="0.6"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/txt_color_primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/contact_us_submit_notice"
                        android:layout_weight="1"
                        android:layout_marginStart="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
        <TextView
            android:textSize="17sp"
            android:textColor="@color/txt_color_primary"
            android:gravity="center"
            android:id="@+id/tv_submit_success"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/contact_us_success_msg"/>
    </FrameLayout>
    <TextView
        android:textSize="15sp"
        android:textColor="@color/txt_color_warning"
        android:layout_gravity="center_horizontal"
        android:id="@+id/tv_warning"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/account_email_set_notice"/>
    <com.aivox.common_ui.LoadingButton
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp"
        android:layout_marginHorizontal="20dp"
        app:lb_enable="false"
        app:lb_text="@string/next"/>
</LinearLayout>
