<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/view_time_use_rule_0"
    android:background="@color/color_66"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/button_click_up_dialog_bgcolor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="0x7f07028d">
        <TextView
            android:textSize="@dimen/font_17sp"
            android:textStyle="bold"
            android:textColor="@color/gray_3"
            android:id="@+id/tv_use_rule"
            android:paddingLeft="0x7f070280"
            android:paddingTop="0x7f070280"
            android:paddingBottom="@dimen/dp_10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/use_rule"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/iv_close"
            android:paddingTop="0x7f070280"
            android:paddingRight="0x7f070280"
            android:paddingBottom="0x7f070280"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/back_b"
            app:layout_constraintBottom_toBottomOf="@+id/tv_use_rule"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_use_rule"/>
        <TextView
            android:textSize="@dimen/font_14sp"
            android:textColor="@color/gray_3"
            android:id="@+id/tv_rule_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="0x7f070280"
            android:layout_marginTop="0x7f070280"
            android:layout_marginRight="0x7f070280"
            android:text="@string/time_use_rule"
            android:lineSpacingMultiplier="1.1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_use_rule"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
