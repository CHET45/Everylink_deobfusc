<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/activity_conversation_recording_0"
    android:background="@color/bg_color_secondary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.aivox.common_ui.HeadTitleLinearView
        android:id="@+id/title_view"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:common_right_icon1_ids="@drawable/ic_more"
        app:common_right_icon1_isVisible="false"
        app:common_right_txt="@string/popup_autoplay"
        app:common_right_txt_color="@color/txt_color_primary"
        app:common_right_txt_isVisible="false"
        app:common_show_switch="false"
        app:common_title_txt=" "
        app:layout_constraintBottom_toTopOf="@+id/ll_content"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_view">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_conversation"
            android:tag="binding_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:gravity="end"
                android:orientation="vertical"
                android:id="@+id/ll_noti"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="22dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/txt_color_primary"
                    android:gravity="center"
                    android:id="@+id/tv_noti"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerview"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:overScrollMode="never"
                app:layout_constraintBottom_toTopOf="@+id/ll_wave"
                app:layout_constraintTop_toBottomOf="@+id/ll_noti"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_wave"
                android:background="@color/bg_color_popup_bar"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="16dp"
                app:layout_constraintBottom_toTopOf="@+id/cl_bottom">
                <ImageView
                    android:id="@+id/iv_wave"
                    android:background="@drawable/ic_audio_wave_frame_0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/cl_bottom"
                android:background="@color/bg_color_popup_bar"
                android:paddingTop="16dp"
                android:paddingBottom="42dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">
                <com.aivox.app.view.ConversationRecordIconView
                    android:id="@+id/iv_mic_left"
                    android:tag="binding_2"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="50dp"
                    app:is_left_icon="true"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:mic_icon="@drawable/ic_mic_other"
                    app:pause_icon="@mipmap/ic_record_pause_dark"
                    app:ripple_color="#e8eef3"
                    app:time_text_color="@color/black_text"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:id="@+id/ll_lang_selected"
                    android:background="@drawable/bg_disable_c80"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_mic_left"
                    app:layout_constraintEnd_toStartOf="@+id/iv_mic_right"
                    app:layout_constraintStart_toEndOf="@+id/iv_mic_left"
                    app:layout_constraintTop_toTopOf="@+id/iv_mic_left">
                    <TextView
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/txt_color_secondary"
                        android:id="@+id/tv_language_from"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"/>
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_lang_mid"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/txt_color_secondary"
                        android:id="@+id/tv_language_to"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
                <com.aivox.app.view.ConversationRecordIconView
                    android:id="@+id/iv_mic_right"
                    android:tag="binding_3"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="50dp"
                    app:is_left_icon="false"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:mic_icon="@drawable/ic_mic_me"
                    app:pause_icon="@mipmap/ic_record_pause_light"
                    app:ripple_color="@color/black_text"
                    app:time_text_color="@color/white"/>
                <TextView
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/txt_color_secondary"
                    android:gravity="center"
                    android:id="@+id/tv_lang_my_side_s2s"
                    android:tag="binding_4"
                    android:background="@drawable/bg_btn_primary_c80"
                    android:layout_width="72dp"
                    android:layout_height="30dp"
                    android:layout_marginBottom="16dp"
                    app:layout_constraintBottom_toTopOf="@+id/iv_mic_left"
                    app:layout_constraintEnd_toEndOf="@+id/iv_mic_left"
                    app:layout_constraintStart_toStartOf="@+id/iv_mic_left"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageView
                    android:id="@+id/iv_switch_lang_s2s"
                    android:tag="binding_5"
                    android:padding="6dp"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_lang_mid_primary"
                    android:layout_marginHorizontal="56dp"
                    app:layout_constraintBottom_toBottomOf="@+id/tv_lang_my_side_s2s"
                    app:layout_constraintEnd_toStartOf="@+id/tv_lang_other_side_s2s"
                    app:layout_constraintStart_toEndOf="@+id/tv_lang_my_side_s2s"
                    app:layout_constraintTop_toTopOf="@+id/tv_lang_my_side_s2s"/>
                <TextView
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/txt_color_secondary"
                    android:gravity="center"
                    android:id="@+id/tv_lang_other_side_s2s"
                    android:tag="binding_6"
                    android:background="@drawable/bg_btn_primary_c80"
                    android:layout_width="72dp"
                    android:layout_height="30dp"
                    android:layout_marginBottom="16dp"
                    app:layout_constraintBottom_toTopOf="@+id/iv_mic_right"
                    app:layout_constraintEnd_toEndOf="@+id/iv_mic_right"
                    app:layout_constraintStart_toStartOf="@+id/iv_mic_right"
                    app:layout_constraintTop_toTopOf="parent"/>
                <androidx.constraintlayout.widget.Group
                    android:id="@+id/group_lang_set_s2s"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:constraint_referenced_ids="tv_lang_my_side_s2s,iv_switch_lang_s2s,tv_lang_other_side_s2s "/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:tag="binding_7"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_top"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:rotation="180"
                app:layout_constraintBottom_toTopOf="@+id/cl_btm"
                app:layout_constraintTop_toTopOf="parent">
                <RelativeLayout
                    android:id="@+id/rl_top"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:layout_marginBottom="10dp"
                    android:paddingHorizontal="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent">
                    <ImageView
                        android:id="@+id/iv_mic_top_start"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_mic_me"
                        android:layout_centerInParent="true"/>
                    <ImageView
                        android:id="@+id/iv_wave_top"
                        android:background="@drawable/wave_anim"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:scrollbarThumbVertical="@color/total_transparent"
                    android:id="@+id/rv_top"
                    android:scrollbars="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:overScrollMode="never"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginVertical="16dp"
                    app:layout_constraintBottom_toTopOf="@+id/rl_top"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.5"/>
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/txt_color_primary"
                    android:gravity="center"
                    android:id="@+id/tv_notice_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingHorizontal="32dp"
                    app:layout_constraintBottom_toTopOf="@+id/rl_top"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_btm"
                android:background="@drawable/bg_recording_btm"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cl_top">
                <RelativeLayout
                    android:id="@+id/rl_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:layout_marginBottom="10dp"
                    android:paddingHorizontal="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent">
                    <ImageView
                        android:id="@+id/iv_mic_bottom_start"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_mic_gray"
                        android:layout_centerInParent="true"/>
                    <ImageView
                        android:id="@+id/iv_wave_bottom"
                        android:background="@drawable/wave_anim_purple"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:scrollbarThumbVertical="@color/total_transparent"
                    android:id="@+id/rv_btm"
                    android:scrollbars="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:overScrollMode="never"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginVertical="16dp"
                    app:layout_constraintBottom_toTopOf="@+id/rl_bottom"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.5"/>
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/txt_color_primary"
                    android:gravity="center"
                    android:id="@+id/tv_notice_btm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingHorizontal="32dp"
                    app:layout_constraintBottom_toTopOf="@+id/rl_bottom"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <LinearLayout
                android:gravity="center"
                android:id="@+id/ll_lang_change_face"
                android:background="@drawable/bg_disable_c80"
                android:layout_width="124dp"
                android:layout_height="32dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/txt_color_secondary"
                    android:id="@+id/tv_language_from_face"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"/>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_lang_mid"/>
                <TextView
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/txt_color_secondary"
                    android:id="@+id/tv_language_to_face"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:rotation="180"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_lang_set_f2f"
                android:background="@drawable/bg_btn_gray_c80"
                android:layout_width="288dp"
                android:layout_height="32dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/txt_color_secondary"
                    android:gravity="center"
                    android:id="@+id/tv_lang_my_side_f2f"
                    android:tag="binding_8"
                    android:background="@drawable/bg_btn_primary_c80"
                    android:layout_width="72dp"
                    android:layout_height="32dp"
                    android:layout_marginBottom="16dp"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/iv_switch_lang_f2f"
                    android:tag="binding_9"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_lang_mid_primary"
                    android:layout_weight="1"
                    android:paddingVertical="6dp"/>
                <TextView
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/txt_color_secondary"
                    android:gravity="center"
                    android:id="@+id/tv_lang_other_side_f2f"
                    android:tag="binding_10"
                    android:background="@drawable/bg_btn_primary_c80"
                    android:layout_width="72dp"
                    android:layout_height="32dp"
                    android:layout_marginBottom="16dp"
                    android:rotation="180"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/vp_guide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <View
        android:id="@+id/view_skip"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/view_prev"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <View
        android:id="@+id/view_next"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <androidx.constraintlayout.widget.Group
        android:id="@+id/gp_guide"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:constraint_referenced_ids="vp_guide, view_skip, view_prev, view_next"/>
</androidx.constraintlayout.widget.ConstraintLayout>
