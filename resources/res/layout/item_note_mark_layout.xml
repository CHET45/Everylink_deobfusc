<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="16dp">
    <ImageView
        android:id="@+id/iv_mark_delete"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_mark_list_delete"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="@+id/tv_mark_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_mark_time"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/txt_color_primary"
        android:gravity="center"
        android:id="@+id/tv_mark_time"
        android:background="@drawable/bg_gary_c40"
        android:layout_width="82dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@+id/iv_mark_delete"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_mark_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/tv_mark_time"
        app:layout_constraintTop_toTopOf="@+id/iv_mark_delete"/>
</androidx.constraintlayout.widget.ConstraintLayout>
