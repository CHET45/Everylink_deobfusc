<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/fragment_main_ai_0"
    android:background="@color/bg_color_secondary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/tv_title"
        android:tag="binding_1"
        android:text="@string/ai_chat_history"
        android:layout_marginStart="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/HomeTitleTextViewStyle"/>
    <ImageView
        android:id="@+id/iv_model"
        android:tag="binding_2"
        android:visibility="gone"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_ai_right"
        android:contentDescription="@null"
        android:layout_marginStart="4dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_title"
        app:layout_constraintStart_toEndOf="@+id/tv_title"
        app:layout_constraintTop_toTopOf="@+id/tv_title"/>
    <ImageView
        android:id="@+id/iv_delete"
        android:tag="binding_3"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_ai_delete"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_title"/>
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/sc_break"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumb="@drawable/switch_thumb"
        android:layout_marginEnd="24dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_title"
        app:layout_constraintEnd_toStartOf="@+id/iv_delete"
        app:layout_constraintTop_toTopOf="@+id/tv_title"
        app:track="@drawable/switch_track_purple"/>
    <View
        android:background="@color/bg_color_divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
    <ImageView
        android:id="@+id/iv_send"
        android:tag="binding_4"
        android:visibility="visible"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_ai_send"
        android:contentDescription="@null"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <ImageView
        android:id="@+id/iv_img"
        android:tag="binding_5"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_ai_add_pic"
        android:contentDescription="@null"
        android:layout_marginEnd="56dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_send"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_send"/>
    <EditText
        android:textSize="14sp"
        android:textColor="@color/txt_color_primary"
        android:textColorHint="@color/txt_color_tertiary"
        android:id="@+id/et_question"
        android:background="@null"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="@string/ai_chat_ask_anything"
        android:lines="1"
        android:inputType="text"
        android:imeOptions="actionSend"
        android:paddingHorizontal="16dp"
        android:autofillHints="@null"
        app:layout_constraintBottom_toTopOf="@+id/iv_send"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_upload"
        android:tag="binding_6"
        android:background="@color/red"
        android:visibility="gone"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        app:cardCornerRadius="5dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/et_question"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:id="@+id/iv_upload"
            android:tag="binding_7"
            android:background="@color/red"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"/>
    </androidx.cardview.widget.CardView>
    <View
        android:id="@+id/v_line"
        android:background="@color/bg_color_divider"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/cv_upload"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="17dp"
        app:layout_constraintBottom_toTopOf="@+id/cv_upload"
        app:layout_constraintTop_toBottomOf="@+id/tv_title">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/ll_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:layout_width="164dp"
                android:layout_height="164dp"
                android:src="@drawable/ic_ai_chat_empty"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"
                android:contentDescription="@null"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/txt_color_tertiary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/no_history_records"
                android:layout_centerInParent="true"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_ai"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
    </LinearLayout>
    <androidx.constraintlayout.widget.Group
        android:id="@+id/group_input"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:constraint_referenced_ids="et_question,iv_img,iv_send,v_line"/>
</androidx.constraintlayout.widget.ConstraintLayout>
