<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_pop_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="17sp"
            android:textColor="@color/txt_color_highlight"
            android:id="@+id/tv_to_old"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/file_sort_newest_to_oldest"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"/>
        <View
            android:layout_width="150dp"
            android:layout_height="1dp"
            style="@style/SettingTileLine"/>
        <TextView
            android:textSize="17sp"
            android:textColor="@color/txt_color_primary"
            android:id="@+id/tv_to_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/file_sort_oldest_to_newest"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
