<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/audio_save_view_layout_0"
    android:background="@drawable/bg_dialog_bottom_dark"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="20dp">
    <com.aivox.common_ui.DialogTitleView
        android:id="@+id/dtv_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:dtv_title="@string/save"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.aivox.common_ui.DialogTitleItemView
        android:id="@+id/dtiv_file"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="8dp"
        app:dtiv_title="@string/record_info_dialog_file_name"
        app:layout_constraintTop_toBottomOf="@+id/dtv_save"/>
    <EditText
        android:textSize="13sp"
        android:textStyle="normal"
        android:id="@+id/et_filename"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/record_info_dialog_file_name_hint"
        app:layout_constraintTop_toBottomOf="@+id/dtiv_file"
        style="@style/MainEditTextStyle"/>
    <com.aivox.common_ui.LoadingButton
        android:id="@+id/btn_continue"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_filename"
        app:lb_text="@string/save"/>
</androidx.constraintlayout.widget.ConstraintLayout>
