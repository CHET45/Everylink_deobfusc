<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/home_enter_view_layout_0"
    android:background="@drawable/bg_home_enter"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_enter_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_home_shorthand"
        app:layout_constraintBottom_toTopOf="@+id/tv_enter_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_enter_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_enter_icon"/>
    <TextView
        android:textColor="@color/txt_color_secondary"
        android:gravity="center"
        android:id="@+id/tv_enter_state"
        android:background="@drawable/bg_highlight_c40"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:drawableStart="@drawable/ic_connected"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_enter_name"
        app:layout_constraintEnd_toEndOf="@+id/tv_enter_name"
        app:layout_constraintStart_toStartOf="@+id/tv_enter_name"
        app:layout_constraintTop_toTopOf="@+id/tv_enter_name"/>
</androidx.constraintlayout.widget.ConstraintLayout>
