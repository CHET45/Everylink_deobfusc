<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:tag="layout/activity_main_0"
    android:background="@color/bg_color_primary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/main_content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <FrameLayout
                android:id="@+id/fragment_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <TextView
                android:textStyle="bold"
                android:textColor="@color/txt_color_secondary"
                android:id="@+id/tv_local_tag"
                android:background="@drawable/shape_red_tag"
                android:padding="4dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="70dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View style="@style/SettingTileLine"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="center_vertical"
            android:id="@+id/layout_footer"
            android:background="@color/bg_color_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RadioGroup
                android:orientation="horizontal"
                android:id="@+id/rg_bottom"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <RadioButton
                    android:id="@+id/foot_bar_home"
                    android:checked="true"
                    android:drawableTop="@drawable/footer_img_home"
                    style="@style/main_footbar_radio"/>
                <RadioButton
                    android:id="@+id/foot_bar_audio"
                    android:visibility="gone"
                    android:drawableTop="@drawable/footer_img_list"
                    style="@style/main_footbar_radio"/>
                <RadioButton
                    android:id="@+id/foot_bar_chat"
                    android:drawableTop="@drawable/footer_img_chat"
                    style="@style/main_footbar_radio"/>
                <RadioButton
                    android:id="@+id/foot_bar_file"
                    android:visibility="gone"
                    android:drawableTop="@drawable/footer_img_file"
                    style="@style/main_footbar_radio"/>
                <RadioButton
                    android:id="@+id/foot_bar_me"
                    android:drawableTop="@drawable/footer_img_profile"
                    style="@style/main_footbar_radio"/>
            </RadioGroup>
            <ImageView
                android:id="@+id/iv_has_news"
                android:visibility="gone"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginTop="0x7f07027d"
                android:src="@drawable/red_dot"
                app:layout_constraintHorizontal_bias="0.865"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/iv_has_sys_notice"
                android:visibility="gone"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginTop="0x7f07027d"
                android:src="@drawable/red_dot"
                app:layout_constraintHorizontal_bias="0.865"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/iv_has_msg_notice"
                android:visibility="gone"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginTop="0x7f07027d"
                android:src="@drawable/red_dot"
                app:layout_constraintHorizontal_bias="0.865"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_close_layout"
        android:background="@color/bg_color_secondary"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/iv_close_x"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/ic_close_x"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/vp_guide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <View
        android:id="@+id/view_skip"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/view_prev"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <View
        android:id="@+id/view_next"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <androidx.constraintlayout.widget.Group
        android:id="@+id/gp_guide"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:constraint_referenced_ids="vp_guide, view_skip, view_prev, view_next"/>
</androidx.constraintlayout.widget.ConstraintLayout>
