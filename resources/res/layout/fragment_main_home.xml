<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/fragment_main_home_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_home_top_bar"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_noti"
            android:background="@drawable/bg_home_top_noti"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textSize="12sp"
                android:textColor="@color/txt_color_primary"
                android:ellipsize="end"
                android:id="@+id/tv_noti"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/update_failed_msg"
                android:maxLines="1"
                android:layout_weight="1"/>
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@mipmap/back_b"
                android:rotation="180"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/iv_splash_logo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_splash_logo"
            android:layout_marginStart="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_noti"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_splash_logo">
            <ImageView
                android:id="@+id/iv_notice"
                android:tag="binding_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_notice"
                android:scaleType="fitXY"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/iv_dot_sys"
                android:background="@drawable/red_dot"
                android:visibility="invisible"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="2dp"
                app:layout_constraintEnd_toEndOf="@+id/iv_notice"
                app:layout_constraintTop_toTopOf="@+id/iv_notice"/>
            <ImageView
                android:id="@+id/iv_dot_msg"
                android:background="@drawable/red_dot"
                android:visibility="invisible"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="2dp"
                app:layout_constraintEnd_toEndOf="@+id/iv_notice"
                app:layout_constraintTop_toTopOf="@+id/iv_notice"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_transcribe"
        android:tag="binding_2"
        android:background="@drawable/bg_enter_transcribe"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="16dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="32dp"
        app:layout_constraintEnd_toStartOf="@+id/ll_translate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_home_top_bar">
        <TextView
            android:id="@+id/tv_shorthand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shorthand"
            style="@style/RecordEnterTextStyle"/>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/ic_home_shorthand"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_translate"
        android:tag="binding_3"
        android:background="@drawable/bg_enter_translate"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginEnd="20dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ll_transcribe"
        app:layout_constraintTop_toTopOf="@+id/ll_transcribe">
        <TextView
            android:id="@+id/tv_translate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/translate"
            style="@style/RecordEnterTextStyle"/>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/ic_home_translate"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_bilingual"
        android:tag="binding_4"
        android:background="@drawable/bg_enter_bilingual"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="32dp"
        app:layout_constraintEnd_toEndOf="@+id/ll_transcribe"
        app:layout_constraintStart_toStartOf="@+id/ll_transcribe"
        app:layout_constraintTop_toBottomOf="@+id/ll_transcribe">
        <TextView
            android:id="@+id/tv_bilingual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bilingual"
            style="@style/RecordEnterTextStyle"/>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/ic_home_bilingual"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_devices"
        android:tag="binding_5"
        android:background="@drawable/bg_enter_device"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="32dp"
        app:layout_constraintEnd_toEndOf="@+id/ll_translate"
        app:layout_constraintStart_toStartOf="@+id/ll_translate"
        app:layout_constraintTop_toBottomOf="@+id/ll_translate">
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tv_devices"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_manager"
                android:layout_centerInParent="true"
                style="@style/RecordEnterTextStyle"/>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/txt_color_secondary"
                android:ellipsize="end"
                android:id="@+id/tv_device_connected"
                android:background="@drawable/bg_device_status"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_connected"
                android:maxLines="1"
                android:drawablePadding="4dp"
                android:layout_centerInParent="true"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                app:drawableStartCompat="@drawable/ic_device_link"/>
        </RelativeLayout>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/ic_home_devices"/>
    </LinearLayout>
    <TextView
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_recent_files"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:text="@string/recent_files"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_bilingual"/>
    <ImageView
        android:id="@+id/iv_import"
        android:tag="binding_6"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_add"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_recent_files"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_recent_files"/>
    <TextView
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/txt_color_tertiary"
        android:id="@+id/tv_no_files"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/no_files"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_recent_files"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_recent"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_recent_files"/>
</androidx.constraintlayout.widget.ConstraintLayout>
