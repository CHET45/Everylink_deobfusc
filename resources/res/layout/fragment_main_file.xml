<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/fragment_main_file_0"
    android:background="@color/bg_color_secondary"
    android:paddingTop="48dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_toolbar"
        android:layout_width="match_parent"
        android:layout_height="44dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:paddingHorizontal="20dp">
            <TextView
                android:textSize="22sp"
                android:textColor="@color/txt_color_primary"
                android:ellipsize="end"
                android:id="@+id/tv_folder_cur"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/home_bottom_files"
                android:maxLines="1"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/iv_import_file"
                android:tag="binding_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_add"
                android:layout_marginStart="16dp"/>
            <ImageView
                android:id="@+id/iv_create_folder"
                android:tag="binding_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_folder_create"
                android:layout_marginStart="16dp"/>
            <ImageView
                android:id="@+id/iv_delete_folder"
                android:tag="binding_3"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_folder_delete"
                android:layout_marginStart="16dp"/>
            <ImageView
                android:id="@+id/iv_edit_folder"
                android:tag="binding_4"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_folder_edit"
                android:layout_marginStart="16dp"/>
            <ImageView
                android:id="@+id/iv_move_folder"
                android:tag="binding_5"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_folder_move"
                android:layout_marginStart="16dp"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/bg_color_secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_search"
            android:tag="binding_6"
            android:background="@drawable/bg_search"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="16dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_search_highlight"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/txt_color_tertiary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/iv_sort"
            android:tag="binding_7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_file_sort"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:paddingVertical="8dp"/>
    <FrameLayout
        android:id="@+id/fl_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <com.aivox.common_ui.LoadingButton
        android:id="@+id/btn_delete_all"
        android:tag="binding_8"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="8dp"
        app:lb_buttonType="warning"
        app:lb_text="@string/delete_all_the_files"/>
</LinearLayout>
