<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/activity_ear_phone_conversation_recording_0"
    android:background="@color/bg_color_secondary"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.aivox.common_ui.HeadTitleLinearView
        android:id="@+id/title_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:common_title_txt="@string/title_interpreting"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_conversation"
        android:tag="binding_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_view">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:overScrollMode="never"
            app:layout_constraintBottom_toTopOf="@+id/ll_wave"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_wave"
            android:background="@color/bg_color_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="16dp"
            app:layout_constraintBottom_toTopOf="@+id/ll_bottom">
            <ImageView
                android:id="@+id/iv_wave"
                android:background="@drawable/ic_audio_wave_frame_0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView
            android:textSize="17sp"
            android:textColor="@color/txt_color_primary"
            android:gravity="center"
            android:id="@+id/tv_speak_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:text="@string/earphone_guide_msg"
            android:drawablePadding="24dp"
            android:paddingHorizontal="20dp"
            app:drawableBottomCompat="@drawable/ic_earphone_use_guide"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_bottom"
            android:background="@color/bg_color_secondary"
            android:paddingTop="16dp"
            android:paddingBottom="42dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent">
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_secondary"
                android:gravity="center"
                android:background="@drawable/bg_gray_round"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:text="L"
                app:layout_constraintBottom_toBottomOf="@+id/tv_left_recording"
                app:layout_constraintEnd_toEndOf="@+id/tv_left_recording"
                app:layout_constraintStart_toStartOf="@+id/tv_left_recording"
                app:layout_constraintTop_toTopOf="@+id/tv_left_recording"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_primary"
                android:gravity="center"
                android:id="@+id/tv_left_recording"
                android:background="@drawable/bg_yellow_round"
                android:visibility="invisible"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="L"
                android:layout_marginEnd="16dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_switch_lang"
                app:layout_constraintEnd_toStartOf="@+id/tv_lang_my_side"
                app:layout_constraintTop_toTopOf="@+id/iv_switch_lang"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_secondary"
                android:gravity="center"
                android:id="@+id/tv_lang_my_side"
                android:tag="binding_2"
                android:background="@drawable/bg_gray_c32"
                android:layout_width="72dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_switch_lang"
                app:layout_constraintEnd_toStartOf="@+id/iv_switch_lang"
                app:layout_constraintTop_toTopOf="@+id/iv_switch_lang"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/iv_switch_lang"
                android:tag="binding_3"
                android:padding="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_lang_mid_primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_secondary"
                android:gravity="center"
                android:id="@+id/tv_lang_other_side"
                android:tag="binding_4"
                android:background="@drawable/bg_gray_c32"
                android:layout_width="72dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_switch_lang"
                app:layout_constraintStart_toEndOf="@+id/iv_switch_lang"
                app:layout_constraintTop_toTopOf="@+id/iv_switch_lang"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_secondary"
                android:gravity="center"
                android:background="@drawable/bg_gray_round"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:text="R"
                app:layout_constraintBottom_toBottomOf="@+id/tv_right_recording"
                app:layout_constraintEnd_toEndOf="@+id/tv_right_recording"
                app:layout_constraintStart_toStartOf="@+id/tv_right_recording"
                app:layout_constraintTop_toTopOf="@+id/tv_right_recording"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_primary"
                android:gravity="center"
                android:id="@+id/tv_right_recording"
                android:background="@drawable/bg_yellow_round"
                android:visibility="invisible"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="R"
                android:layout_marginStart="16dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_switch_lang"
                app:layout_constraintStart_toEndOf="@+id/tv_lang_other_side"
                app:layout_constraintTop_toTopOf="@+id/iv_switch_lang"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
