<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_content"
    android:tag="layout/remain_time_item_view_layout_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="22sp"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_time_remain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/view_label"
        android:background="@drawable/bg_highlight_c40"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@+id/tv_time_remain"
        app:layout_constraintTop_toBottomOf="@+id/tv_time_remain"/>
    <TextView
        android:textSize="15sp"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_time_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/view_label"
        app:layout_constraintStart_toEndOf="@+id/view_label"
        app:layout_constraintTop_toTopOf="@+id/view_label"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/txt_color_tertiary"
        android:id="@+id/tv_time_expired"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_label"/>
    <View
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_time_expired"
        style="@style/SettingTileLine"/>
</androidx.constraintlayout.widget.ConstraintLayout>
