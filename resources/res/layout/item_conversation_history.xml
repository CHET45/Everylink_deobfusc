<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl"
    android:tag="layout/item_conversation_history_0"
    android:background="@drawable/bg_conversation_left"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginHorizontal="20dp"
    android:paddingHorizontal="20dp"
    android:paddingVertical="12dp"
    app:layout_constraintTop_toTopOf="parent">
    <TextView
        android:textSize="17sp"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingMultiplier="1.3"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/line_content"
        android:background="@color/bg_color_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:scaleType="fitXY"
        app:layout_constraintTop_toBottomOf="@+id/tv_content"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/txt_color_primary"
        android:id="@+id/tv_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingMultiplier="1.3"
        app:layout_constraintTop_toBottomOf="@+id/line_content"/>
</androidx.constraintlayout.widget.ConstraintLayout>
