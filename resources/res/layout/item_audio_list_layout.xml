<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_content"
        android:background="@color/bg_item_normal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <View
            android:id="@+id/v_folder"
            android:layout_width="4dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_top"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/iv_loading"
                android:visibility="gone"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="1dp"
                android:src="@drawable/ic_btn_loading"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/txt_color_primary"
                android:ellipsize="end"
                android:id="@+id/item_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:lineSpacingExtra="0dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toStartOf="@+id/iv_ai_summary"
                app:layout_constraintStart_toEndOf="@+id/iv_loading"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_goneMarginStart="0dp"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/txt_color_tertiary"
                android:id="@+id/item_info_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/item_name"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/txt_color_tertiary"
                android:id="@+id/item_info_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="2dp"
                app:drawableStartCompat="@drawable/ic_audio_wave_dark"
                app:layout_constraintBottom_toBottomOf="@+id/item_info_tv"
                app:layout_constraintStart_toEndOf="@+id/item_info_tv"
                app:layout_constraintTop_toTopOf="@+id/item_info_tv"/>
            <ImageView
                android:id="@+id/iv_ai_summary"
                android:visibility="gone"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_ai_star"
                app:layout_constraintBottom_toBottomOf="@+id/item_name"
                app:layout_constraintEnd_toStartOf="@+id/iv_favorite"
                app:layout_constraintTop_toTopOf="@+id/item_name"/>
            <ImageView
                android:id="@+id/iv_favorite"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_star_normal"
                android:paddingStart="8dp"
                android:paddingVertical="4dp"
                app:layout_constraintBottom_toBottomOf="@+id/item_name"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/item_name"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/ll_trans_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@+id/item_info_duration"
                app:layout_constraintStart_toEndOf="@+id/item_info_duration"
                app:layout_constraintTop_toTopOf="@+id/item_info_duration">
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/txt_color_tertiary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "/>
                <ImageView
                    android:id="@+id/iv_trans_status"
                    android:background="@drawable/ic_transcribe_frame_0"
                    android:layout_width="14dp"
                    android:layout_height="14dp"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
