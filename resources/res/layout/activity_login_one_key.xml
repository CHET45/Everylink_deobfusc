<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@+id/ll"
    android:tag="layout/activity_login_one_key_0"
    android:background="@drawable/bg_page_gradient"
    android:paddingBottom="80dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="24dp">
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="4"/>
    <TextView
        android:textSize="52sp"
        android:textStyle="bold"
        android:textColor="@color/txt_color_primary"
        android:gravity="center"
        android:id="@+id/tv_slogan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/app_slogan"
        android:maxLines="1"
        android:autoSizeTextType="uniform"
        android:autoSizeStepGranularity="1sp"/>
    <ImageView
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_splash_title"/>
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="4"/>
    <com.aivox.common_ui.LoadingButton
        android:id="@+id/btn_login"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:lb_enable="false"
        app:lb_text="@string/login_2sendcode_accounttype_email"/>
    <com.aivox.common_ui.LoadingButton
        android:id="@+id/btn_login_phone"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        app:lb_enable="false"
        app:lb_text="@string/login_2sendcode_accounttype_phone"/>
    <com.aivox.common_ui.LoadingButton
        android:id="@+id/btn_login_email"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        app:lb_buttonType="stroke"
        app:lb_enable="false"
        app:lb_text="@string/login_2sendcode_accounttype_email"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="100dp"
        android:paddingHorizontal="16dp">
        <CheckBox
            android:id="@+id/cb_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            android:button="@drawable/check_box_dialog"
            android:scaleX="0.5"
            android:scaleY="0.5"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/txt_color_tertiary"
            android:id="@+id/tv_policy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/account_privacy_policy"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/iv_google_login"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_google_login"/>
</LinearLayout>
