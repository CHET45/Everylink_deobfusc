<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:tag="layout/activity_ai_chat_edit_0"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="44dp">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/txt_color_tertiary"
            android:gravity="center"
            android:id="@+id/tv_edit_cancel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/cancel"
            android:paddingHorizontal="20dp"/>
        <TextView
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/txt_color_primary"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/all_edit"
            android:layout_weight="1"
            android:paddingHorizontal="20dp"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/txt_color_tertiary"
            android:gravity="center"
            android:id="@+id/tv_edit_save"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/save"
            android:paddingHorizontal="20dp"/>
    </LinearLayout>
    <EditText
        android:textSize="17sp"
        android:gravity="top"
        android:id="@+id/et_content"
        android:background="@drawable/bg_ai_chat_edit"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="16dp"/>
</LinearLayout>
