<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/activity_record_import_0"
    android:background="@color/bg_color_secondary"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.aivox.common_ui.HeadTitleLinearView
            android:id="@+id/title_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:common_title_txt="@string/import_audio_file"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_search_layout"
            android:background="@drawable/serach_shape"
            android:visibility="invisible"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="0x7f07027d"
            android:layout_marginBottom="0x7f07027d"
            android:layout_centerVertical="true"
            android:layout_marginStart="0x7f070280"
            android:layout_marginEnd="0x7f07027d"
            app:layout_constraintBottom_toBottomOf="@+id/title_view"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/barrier_cancel">
            <ImageView
                android:layout_gravity="center_vertical"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginLeft="0x7f07027d"
                android:layout_marginRight="0x7f07027d"
                android:src="@mipmap/home_search"
                android:scaleType="fitXY"/>
            <com.aivox.common_ui.PowerfulEditText
                android:textSize="12sp"
                android:textColor="@color/gray_3"
                android:textColorHint="@color/gray_9"
                android:ellipsize="end"
                android:id="@+id/et_search_import"
                android:background="@null"
                android:paddingTop="0x7f07027d"
                android:paddingBottom="0x7f07027d"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/audio_list_serach_hint_local"
                android:maxLines="1"
                android:layout_weight="1"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:paddingEnd="0x7f07027d"
                app:funcType="canClear"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/iv_search"
            android:padding="0x7f07027d"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_search"
            android:layout_marginEnd="0x7f070280"
            app:layout_constraintBottom_toBottomOf="@+id/ll_search_layout"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/ll_search_layout"/>
        <TextView
            android:textSize="0x7f0702b1"
            android:textColor="@color/gray_3"
            android:id="@+id/tv_search_cancel"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:layout_marginEnd="0x7f070280"
            app:layout_constraintBottom_toBottomOf="@+id/ll_search_layout"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/ll_search_layout"/>
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="left"
            app:constraint_referenced_ids="iv_search,tv_search_cancel"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <RelativeLayout
        android:id="@+id/refreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="1dp"
        android:layout_weight="1">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview"
            android:visibility="visible"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/ll_empty"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/EmptyTextStyle"/>
            <TextView
                android:id="@+id/tv"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0x7f070280"
                android:text="@string/audio_list_null"/>
        </LinearLayout>
        <ScrollView
            android:id="@+id/sv_import_notice"
            android:background="@color/bg_color_secondary"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_stroke_c20"
                    android:padding="18dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">
                    <TextView
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/txt_color_primary"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/import_notice_title_1"/>
                    <TextView
                        android:textSize="17sp"
                        android:textColor="@color/txt_color_primary"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/import_notice_msg_1"/>
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:src="@drawable/pic_import_notice_1"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_stroke_c20"
                    android:padding="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/txt_color_primary"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/import_notice_title_2"/>
                    <TextView
                        android:textSize="17sp"
                        android:textColor="@color/txt_color_primary"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/import_notice_msg_2"/>
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/pic_import_notice_2"/>
                    <TextView
                        android:textStyle="bold"
                        android:textColor="@color/txt_color_secondary"
                        android:gravity="center"
                        android:id="@+id/tv_do_import"
                        android:background="@drawable/bg_btn_highlight_c80"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/do_import"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </RelativeLayout>
</LinearLayout>
