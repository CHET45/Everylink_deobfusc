<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:tag="layout/item_ble_device_0"
    android:background="@drawable/bg_device_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp">
    <ImageView
        android:id="@+id/iv_device_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/pic_device_aidio_x1"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/color_191D21"
        android:id="@+id/tv_device_desc"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="17sp"
            android:textColor="@color/txt_color_primary"
            android:id="@+id/tv_device_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <ImageView
            android:id="@+id/iv_device_signal"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
</LinearLayout>
