<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="0x7f070282">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:background="@drawable/dialog_bg_white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="0x7f0702b2"
            android:textStyle="bold"
            android:textColor="@color/gray_3"
            android:gravity="center"
            android:id="@+id/title"
            android:background="@color/home_bgcolor"
            android:padding="0x7f070280"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/reminder"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title">
            <com.aivox.common_ui.MyMaxHeightWebView
                android:id="@+id/webview"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:scrollbarSize="@dimen/dp_4"
                android:scrollbarThumbVertical="@color/gray10"
                android:textSize="0x7f0702b2"
                android:textColor="@color/gray_3"
                android:id="@+id/tv_center"
                android:paddingLeft="0x7f070284"
                android:paddingTop="0x7f070280"
                android:paddingRight="0x7f070284"
                android:paddingBottom="0x7f070284"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="400dp"
                android:lineSpacingExtra="0x7f07027d"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@+id/line2"
            android:background="@color/line_h"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            app:layout_constraintTop_toBottomOf="@+id/cl_center"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btns_layout"
            android:background="@color/home_bgcolor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/line2">
            <TextView
                android:textSize="0x7f0702b2"
                android:textStyle="bold"
                android:textColor="@color/gray_9"
                android:gravity="center"
                android:id="@+id/left"
                android:padding="0x7f070280"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/protocal_cancel"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@+id/line_bottom_2"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:layout_gravity="center_vertical"
                android:id="@+id/line_bottom_2"
                android:background="@color/white"
                android:layout_width="1dp"
                android:layout_height="0x7f070284"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/left"
                app:layout_constraintRight_toLeftOf="@+id/right"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="0x7f0702b2"
                android:textStyle="bold"
                android:textColor="@color/home_txt"
                android:gravity="center"
                android:id="@+id/right"
                android:padding="0x7f070280"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/protocal_sure"
                app:layout_constraintLeft_toRightOf="@+id/line_bottom_2"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
